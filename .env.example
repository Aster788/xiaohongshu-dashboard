# Put secrets in `.env.local` (Next.js default) or `.env`.
# `npm run db:*` uses dotenv-cli `-c development` (same file order as below).
# `prisma.config.ts` also loads these files for Prisma CLI when a config file is present:
#   .env, .env.development, .env.local, .env.development.local
# Never commit real passwords.

# PostgreSQL / Neon
# Use the full Neon connection string as DATABASE_URL.
# For production on Vercel, this repo currently expects the pooled/runtime URL here.
DATABASE_URL=

# Upload-related API auth for:
# /api/upload, /api/excel/parse, /api/settings, /api/notes
# Optional in local dev if unset; required in production.
UPLOAD_SECRET=
